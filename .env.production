MONGO_URI=mongodb://localhost:27017/taskflow
MONGO_DB_NAME=taskflow
MONGO_MIN_POOL_SIZE=5
MONGO_MAX_POOL_SIZE=10

# App
NODE_ENV=production
PORT=3000
TZ=UTC
CORS_URL=*
LOG_DIR=logs

# Auth
JWT_SECRET=your_jwt_secret
ACCESS_TOKEN_VALIDITY_SEC=3600
REFRESH_TOKEN_VALIDITY_SEC=86400
TOKEN_ISSUER=taskflow
TOKEN_AUDIENCE=taskflow_users
SUPER_ADMIN_API_KEY=your_super_admin_api_key

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Cache
CONTENT_CACHE_DURATION_MILLIS=600000

