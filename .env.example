# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/taskflow
MONGO_DB_NAME=taskflow
MONGO_MIN_POOL_SIZE=5
MONGO_MAX_POOL_SIZE=10

# App Configuration
NODE_ENV=development
PORT=8000
TZ=UTC
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_DIR=logs

# Auth Configuration
JWT_SECRET=your_jwt_secret_here
ACCESS_TOKEN_VALIDITY_SEC=3600
REFRESH_TOKEN_VALIDITY_SEC=86400
TOKEN_ISSUER=taskflow
TOKEN_AUDIENCE=taskflow_users
SUPER_ADMIN_API_KEY=your_super_admin_api_key_here

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Cache Configuration
CONTENT_CACHE_DURATION_MILLIS=600000

# Throttler Configuration
THROTTLER_TTL=60000
THROTTLER_LIMIT=60
THROTTLER_REDIS_ENABLED=false

# Firebase (Optional)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=your_firebase_client_email
FIREBASE_PRIVATE_KEY=your_firebase_private_key
